container_image_payment_service = "123456789012.dkr.ecr.eu-west-1.amazonaws.com/team-pulse-payment-service:latest"

stripe_secret_key_secret_arn    = "arn:aws:secretsmanager:eu-west-1:123456789012:secret:team-pulse/stripe-secret-key"
