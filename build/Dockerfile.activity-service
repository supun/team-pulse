FROM golang:1.24-alpine AS builder
WORKDIR /src

COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/activity-service ./cmd/activity-service

FROM alpine:3.22
RUN adduser -D -u 10001 appuser
USER appuser
WORKDIR /app
COPY --from=builder /out/activity-service /app/activity-service
EXPOSE 8081
ENTRYPOINT ["/app/activity-service"]
