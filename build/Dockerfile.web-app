FROM golang:1.24-alpine AS builder
WORKDIR /src

COPY go.mod ./
COPY cmd ./cmd
COPY internal ./internal
COPY web ./web

RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -o /out/web-app ./cmd/web-app

FROM alpine:3.22
RUN adduser -D -u 10001 appuser
USER appuser
WORKDIR /app
COPY --from=builder /out/web-app /app/web-app
COPY --from=builder /src/web /app/web
EXPOSE 3000
ENTRYPOINT ["/app/web-app"]
